<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.personal.kafka.pilot.ui.MainController"
            prefHeight="700.0" prefWidth="1200.0">

    <!-- Custom title bar -->
    <top>
        <VBox style="-fx-background-color: #1a252f;">
            <!-- Common section: Kafka Brokers Management + Maven dependency -->
            <GridPane hgap="10" vgap="5" style="-fx-padding: 6 15 6 15; -fx-background-color: #2c3e50;">
                <columnConstraints>
                    <ColumnConstraints minWidth="130" prefWidth="130"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="90" prefWidth="90"/>
                </columnConstraints>

                <!-- Row 0: Active Pod (shows connected pod names only) -->
                <Label text="Active Pod(s):" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <TextField fx:id="activePodsField" promptText="Not Connected" editable="false" HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #34495e; -fx-text-fill: #ecf0f1;"/>
                </HBox>

                <!-- Row 1: Selected for Work (dropdown + Connect) -->
                <Label text="Selected for Work:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-text-fill: #f39c12; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <ComboBox fx:id="selectedForWorkComboBox" promptText="Select Pod for Operations"
                              editable="false" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="connectButton" text="Connect" onAction="#handleConnect"
                            styleClass="btn-green" style="-fx-font-size: 11px;"/>
                </HBox>

                <!-- Row 2: Broker Details (Name + Hosts + Add/Update/Del) -->
                <Label text="Broker Details:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <TextField fx:id="brokerNameField" promptText="Name (e.g., POD1)" prefWidth="150"/>
                    <TextField fx:id="brokerServersField" promptText="host1:9092,host2:9092" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="addBrokerButton" text="Add" onAction="#handleAddBroker"
                            styleClass="btn-green" style="-fx-font-size: 11px;"/>
                    <Button fx:id="updateBrokerButton" text="Update" onAction="#handleUpdateBroker"
                            style="-fx-font-size: 11px;"/>
                    <Button fx:id="deleteBrokerButton" text="Delete" onAction="#handleDeleteBroker"
                            style="-fx-font-size: 11px; -fx-text-fill: #c0392b;"/>
                </HBox>

                <!-- Row 3: SSL/TLS Configuration (Collapsible) - Right aligned below broker buttons -->
                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="1">
                    <TitledPane fx:id="sslConfigPane" text="SSL/TLS Configuration (Optional)" expanded="false" collapsible="true"
                                HBox.hgrow="ALWAYS" prefWidth="800">
                        <VBox spacing="8" style="-fx-padding: 8;">
                            <!-- Security Protocol -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Security Protocol:" minWidth="130"/>
                                <ComboBox fx:id="sslSecurityProtocolCombo" promptText="PLAINTEXT" prefWidth="180">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="PLAINTEXT"/>
                                            <String fx:value="SSL"/>
                                            <String fx:value="SASL_PLAINTEXT"/>
                                            <String fx:value="SASL_SSL"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <CheckBox fx:id="sslEnabledCheckBox" text="Enable SSL/TLS" style="-fx-text-fill: #333;"/>
                            </HBox>

                            <!-- Truststore Section -->
                            <Label text="Truststore (Server Authentication):" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Location:" minWidth="80"/>
                                <TextField fx:id="sslTruststoreLocationField" promptText="/path/to/truststore.jks" HBox.hgrow="ALWAYS"/>
                                <Button text="Browse..." onAction="#handleBrowseTruststore" style="-fx-font-size: 11px;"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Password:" minWidth="80"/>
                                <PasswordField fx:id="sslTruststorePasswordField" promptText="Truststore password" prefWidth="200"/>
                                <Label text="Type:" minWidth="50"/>
                                <ComboBox fx:id="sslTruststoreTypeCombo" promptText="JKS" prefWidth="100">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="JKS"/>
                                            <String fx:value="PKCS12"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </HBox>

                            <!-- Keystore Section (Mutual TLS) -->
                            <Label text="Keystore (Client Authentication - Mutual TLS, Optional):" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Location:" minWidth="80"/>
                                <TextField fx:id="sslKeystoreLocationField" promptText="/path/to/keystore.jks (optional)" HBox.hgrow="ALWAYS"/>
                                <Button text="Browse..." onAction="#handleBrowseKeystore" style="-fx-font-size: 11px;"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Password:" minWidth="80"/>
                                <PasswordField fx:id="sslKeystorePasswordField" promptText="Keystore password" prefWidth="200"/>
                                <Label text="Type:" minWidth="50"/>
                                <ComboBox fx:id="sslKeystoreTypeCombo" promptText="JKS" prefWidth="100">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="JKS"/>
                                            <String fx:value="PKCS12"/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label text="Key Password:" minWidth="80"/>
                                <PasswordField fx:id="sslKeyPasswordField" promptText="Private key password (if different)" prefWidth="280"/>
                            </HBox>

                            <!-- Endpoint Identification -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Endpoint ID Algorithm:" minWidth="130"/>
                                <ComboBox fx:id="sslEndpointAlgorithmCombo" promptText="https" prefWidth="150">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                            <String fx:value="https"/>
                                            <String fx:value=""/>
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                                <Label text="(empty = disable hostname verification)" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                            </HBox>

                            <!-- SSL Status Label -->
                            <Label fx:id="sslConfigStatusLabel" text="" style="-fx-font-size: 11px; -fx-text-fill: #27ae60;"/>
                        </VBox>
                    </TitledPane>
                </HBox>

                <!-- Row 4: Maven dependency -->
                <Label text="Maven Dependency:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="4" GridPane.columnIndex="1">
                    <TextField fx:id="mavenDependencyField"
                               promptText="groupId:artifactId:version"
                               HBox.hgrow="ALWAYS"/>
                    <Button text="Download" onAction="#handleDownloadDependency"
                            styleClass="btn-blue" style="-fx-font-size: 12px;"/>
                </HBox>

                <!-- Row 5: Maven Repo URL -->
                <Label text="Maven Repo URL:" GridPane.rowIndex="5" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="5" GridPane.columnIndex="1">
                    <TextField fx:id="mavenRepoUrlField"
                               promptText="https://your-repo/maven2/ (optional, leave blank for Maven Central)"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Row 6: Configuration -->
                <Label text="Configuration:" GridPane.rowIndex="6" GridPane.columnIndex="0"
                       style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="6" GridPane.columnIndex="1">
                    <ComboBox fx:id="configsCombo" promptText="Select saved config" prefWidth="200"/>
                    <Button text="Load" onAction="#handleLoadConfig"/>
                    <Button text="Save" onAction="#handleSaveConfig"/>
                    <Button text="Delete" onAction="#handleDeleteConfig"
                            style="-fx-font-size: 11px; -fx-text-fill: #c0392b;"/>
                </HBox>
            </GridPane>

        </VBox>
    </top>

    <center>
        <VBox spacing="0" style="-fx-fill-height: true;">
            <!-- Main tab pane -->
            <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"
                     style="-fx-tab-min-height: 36px;" minHeight="300">

                <!-- ===== TAB 1: Search ===== -->
                <Tab text="🔍  Search">
                    <BorderPane>
                        <!-- Scrollable parameters in center -->
                        <center>
                            <ScrollPane fitToWidth="true">
                                <VBox spacing="10" style="-fx-padding: 12;">
                                <TitledPane text="Search Parameters" expanded="true" collapsible="false">
                                    <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                                        <fx:define>
                                            <ToggleGroup fx:id="searchPartitionGroup"/>
                                            <ToggleGroup fx:id="searchTimeGroup"/>
                                        </fx:define>
                                        <columnConstraints>
                                            <ColumnConstraints minWidth="160" prefWidth="160"/>
                                            <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>

                                        <Label text="Topic: *" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <ComboBox fx:id="searchTopicComboBox" promptText="Select or type topic" prefWidth="300" editable="true"/>
                                        </HBox>

                                        <Label text="Search Text:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <HBox spacing="6" alignment="CENTER_LEFT" GridPane.rowIndex="1" GridPane.columnIndex="1">
                                            <TextField fx:id="searchTextFilter" promptText="term 1 (optional)"
                                                       HBox.hgrow="ALWAYS"/>
                                            <ComboBox fx:id="searchOperatorCombo" prefWidth="70"/>
                                            <TextField fx:id="searchTextFilter2" promptText="term 2 (optional)"
                                                       HBox.hgrow="ALWAYS"/>
                                        </HBox>

                                        <Label text="Partition:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="2" GridPane.columnIndex="1">
                                            <RadioButton fx:id="searchAllPartitions" text="All" selected="true"
                                                         toggleGroup="$searchPartitionGroup"/>
                                            <RadioButton fx:id="searchSpecificPartition" text="Specific:"
                                                         toggleGroup="$searchPartitionGroup"/>
                                            <ComboBox fx:id="searchPartitionField" promptText="partition #" prefWidth="100"
                                                       disable="true" editable="true"/>
                                            <Label text="Offset:" disable="true" fx:id="offsetLabel"/>
                                            <TextField fx:id="sourceOffsetField" promptText="optional — leave empty for latest" prefWidth="220"
                                                       disable="true"/>
                                        </HBox>

                                        <Label text="Time Range:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="1">
                                            <RadioButton fx:id="searchNoTimeRange" text="No filter" selected="true"
                                                         toggleGroup="$searchTimeGroup"/>
                                            <RadioButton fx:id="searchWithTimeRange" text="Time range:"
                                                         toggleGroup="$searchTimeGroup"/>
                                        </HBox>

                                        <Label text="From:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <HBox fx:id="searchFromTimeBox" spacing="5" alignment="CENTER_LEFT"
                                              GridPane.rowIndex="4" GridPane.columnIndex="1" disable="true">
                                            <DatePicker fx:id="searchFromDatePicker" prefWidth="140" promptText="From date"/>
                                            <Spinner fx:id="searchFromHourSpinner" prefWidth="58" editable="true"/>
                                            <Label text="h"/>
                                            <Spinner fx:id="searchFromMinuteSpinner" prefWidth="58" editable="true"/>
                                            <Label text="m"/>
                                        </HBox>

                                        <Label text="To:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                        <HBox fx:id="searchToTimeBox" spacing="5" alignment="CENTER_LEFT"
                                              GridPane.rowIndex="5" GridPane.columnIndex="1" disable="true">
                                            <DatePicker fx:id="searchToDatePicker" prefWidth="140" promptText="To date"/>
                                            <Spinner fx:id="searchToHourSpinner" prefWidth="58" editable="true"/>
                                            <Label text="h"/>
                                            <Spinner fx:id="searchToMinuteSpinner" prefWidth="58" editable="true"/>
                                            <Label text="m"/>
                                        </HBox>

                                        <Label text="Max Results:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                                        <TextField fx:id="searchMaxResults" promptText="100  (used by Search All only)"
                                                   GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                                        <Label text="Key Deserializer:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                                        <TextField fx:id="sourceKeyDeserializerField"
                                                   promptText="org.apache.kafka.common.serialization.StringDeserializer"
                                                   GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                                        <Label text="Value Deserializer:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                                        <TextField fx:id="searchValueDeserializerField"
                                                   promptText="org.apache.kafka.common.serialization.StringDeserializer"
                                                   GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                                        <CheckBox fx:id="decodeAsFlatbufCheck"
                                                  text="Decode value as FlatBuffers"
                                                  GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                                        <Label text="FlatBuf Class Name:" GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                                        <TextField fx:id="searchFlatbufClassNameField"
                                                   promptText="com.example.MyTable  (optional, for FlatBuffers decode)"
                                                   GridPane.rowIndex="10" GridPane.columnIndex="1"/>

                                        <HBox fx:id="searchFromBeginningBox" spacing="8" alignment="CENTER_LEFT"
                                              GridPane.rowIndex="11" GridPane.columnIndex="1"
                                              visible="true" managed="true">
                                            <CheckBox fx:id="searchFromBeginningCheck" text="Search from beginning"/>
                                            <Label text="⚠ Very slow — scans all messages from earliest offset"
                                                   style="-fx-text-fill: #e67e22; -fx-font-size: 11px;"/>
                                        </HBox>
                                    </GridPane>
                                </TitledPane>

                                </VBox>
                            </ScrollPane>
                        </center>
                        <!-- Action bar + Results always visible at bottom -->
                        <bottom>
                            <VBox>
                                <!-- Action bar -->
                                <HBox spacing="10" style="-fx-padding: 8 12 8 12; -fx-background-color: #f8f8f8; -fx-border-color: #ddd; -fx-border-width: 1 0 0 0;" alignment="CENTER_LEFT">
                                    <Button fx:id="searchButton" text="🔍  Search All" onAction="#handleSearch"
                                            styleClass="btn-purple" style="-fx-font-size: 13px; -fx-padding: 8 20;"/>
                                    <Button fx:id="stopSearchButton" text="⏹ Stop" onAction="#handleStopSearch"
                                            styleClass="btn-red" style="-fx-font-size: 13px; -fx-padding: 8 16;" disable="true"/>
                                    <Button fx:id="peekOneButton" text="↓ Peek One" onAction="#handlePeekOne"
                                            styleClass="btn-green" style="-fx-font-size: 13px; -fx-padding: 8 20;">
                                        <tooltip><Tooltip text="Fetch one message (latest, or at specified offset when Specific partition is selected)"/></tooltip>
                                    </Button>
                                    <Button fx:id="startTailButton" text="⟳ Live Tail" onAction="#handleStartTail"
                                            styleClass="btn-blue" style="-fx-font-size: 13px; -fx-padding: 8 20;">
                                        <tooltip><Tooltip text="Poll for new messages every 5s — newest first. Stops after 200 messages or 5 minutes."/></tooltip>
                                    </Button>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="searchStatusLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                                    <Button fx:id="toggleSearchResultsButton" text="▲ Results" onAction="#handleToggleSearchResults"
                                            style="-fx-font-size: 11px; -fx-padding: 6 12;"/>
                                    <Button text="Export" onAction="#handleExportSearchResults"
                                            style="-fx-font-size: 11px; -fx-padding: 6 12;"/>
                                </HBox>
                                <!-- Results -->
                                <VBox fx:id="searchResultsBox" spacing="6" style="-fx-padding: 10;" prefHeight="250" minHeight="150" visible="false" managed="false">
                                    <Label text="Results" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                    <TextArea fx:id="searchResultsArea" editable="false" VBox.vgrow="ALWAYS" prefRowCount="10"
                                              style="-fx-font-family: 'Courier New'; -fx-font-size: 11px;"
                                              promptText="Results will appear here…"/>
                                </VBox>
                            </VBox>
                        </bottom>
                    </BorderPane>
                </Tab>

                <!-- ===== TAB 2: Push Messages ===== -->
                <Tab text="📤  Push Messages">
                    <VBox>
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                            <VBox spacing="12" style="-fx-padding: 15;">

                                <TitledPane text="Message Template (JSON)" expanded="true" collapsible="false">
                                    <VBox spacing="5" style="-fx-padding: 10;">
                                        <TextArea fx:id="pushMessageTemplateArea" prefRowCount="7"/>
                                    </VBox>
                                </TitledPane>

                                <TitledPane text="Destination &amp; Serializer" expanded="true" collapsible="false">
                                    <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                                        <columnConstraints>
                                            <ColumnConstraints minWidth="170" prefWidth="170"/>
                                            <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>

                                        <Label text="Destination Topic: *" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <HBox spacing="5" alignment="CENTER_LEFT" GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <ComboBox fx:id="pushTopicComboBox" promptText="Select or type topic" prefWidth="300" editable="true"/>
                                        </HBox>

                                        <Label text="Key Serializer:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <TextField fx:id="keySerializerField"
                                                   promptText="org.apache.kafka.common.serialization.StringSerializer"
                                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                        <Label text="Value Serializer:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="valueSerializerField"
                                                   promptText="org.apache.kafka.common.serialization.StringSerializer"
                                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                        <Label text="Protobuf Class Name:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <TextField fx:id="protobufClassNameField"
                                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                        <Label text="FlatBuf Class Name:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="pushFlatbufClassNameField"
                                                   promptText="com.example.flatbuff.dto.MyDocument"
                                                   GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                                        <CheckBox fx:id="pushFlatbufModeCheck"
                                                  text="Encode as FlatBuffers (auto ByteArraySerializer)"
                                                  GridPane.rowIndex="5" GridPane.columnIndex="0"
                                                  GridPane.columnSpan="2"/>

                                    </GridPane>
                                </TitledPane>

                                <TitledPane text="Target Partition and Key" expanded="true" collapsible="false">
                                    <VBox spacing="8" style="-fx-padding: 10;">
                                        <fx:define>
                                            <ToggleGroup fx:id="partitionKeyGroup"/>
                                        </fx:define>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <RadioButton fx:id="partitionKeyAll" text="All (auto)" selected="true"
                                                         toggleGroup="$partitionKeyGroup"/>
                                        </HBox>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <RadioButton fx:id="partitionKeySpecific" text="Specific partition:"
                                                         toggleGroup="$partitionKeyGroup"/>
                                            <ComboBox fx:id="targetPartitionField" promptText="partition #" prefWidth="100"
                                                       disable="true" editable="true"/>
                                        </HBox>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <RadioButton fx:id="partitionKeyField" text="Use field from template as key:"
                                                         toggleGroup="$partitionKeyGroup"/>
                                            <ComboBox fx:id="keyFieldComboBox" promptText="Select field" prefWidth="150" disable="true"/>
                                        </HBox>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <RadioButton fx:id="partitionKeyConstant" text="Constant key:"
                                                         toggleGroup="$partitionKeyGroup"/>
                                            <TextField fx:id="keyConstantField" promptText="Enter key value" prefWidth="200" disable="true"/>
                                        </HBox>
                                    </VBox>
                                </TitledPane>

                                <TitledPane text="Test Configuration" expanded="true" collapsible="false">
                                    <GridPane hgap="10" vgap="8" style="-fx-padding: 10;">
                                        <columnConstraints>
                                            <ColumnConstraints minWidth="170" prefWidth="170"/>
                                            <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>

                                        <Label text="Total Messages: *" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="messageCountField" promptText="1"
                                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                        <Label text="Thread Pool Size: *" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <TextField fx:id="threadPoolSizeField" promptText="1"
                                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                        <Label text="Batch Size: *" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="batchSizeField" promptText="1"
                                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </TitledPane>

                                <TitledPane text="Field Manipulation" expanded="true" collapsible="false">
                                    <VBox spacing="10" style="-fx-padding: 10;">

                                        <!-- Auto-Increment -->
                                        <Label text="Auto-Increment (fieldName:startValue:step)" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                                        <HBox spacing="6" alignment="CENTER_LEFT">
                                            <ComboBox fx:id="autoIncrementFieldPicker" promptText="Pick field" prefWidth="160"/>
                                            <TextField fx:id="autoIncrementStartField" promptText="start" prefWidth="60"/>
                                            <TextField fx:id="autoIncrementStepField" promptText="step" prefWidth="60"/>
                                            <Button text="+ Add" onAction="#handleAddAutoIncrement" style="-fx-font-size: 11px; -fx-padding: 3 10;"/>
                                            <Button text="Clear" onAction="#handleClearAutoIncrement" style="-fx-font-size: 11px; -fx-padding: 3 10;"/>
                                        </HBox>
                                        <TextField fx:id="autoIncrementFieldsField" promptText="assetId:1000:1, id:1:1" style="-fx-font-size: 11px;"/>

                                        <!-- Rotation -->
                                        <Label text="Rotation (fieldName:val1,val2,val3 — semicolons separate fields)" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                                        <HBox spacing="6" alignment="CENTER_LEFT">
                                            <ComboBox fx:id="rotationFieldPicker" promptText="Pick field" prefWidth="160"/>
                                            <TextField fx:id="rotationValuesField" promptText="val1,val2,val3" prefWidth="200"/>
                                            <Button text="+ Add" onAction="#handleAddRotation" style="-fx-font-size: 11px; -fx-padding: 3 10;"/>
                                            <Button text="Clear" onAction="#handleClearRotation" style="-fx-font-size: 11px; -fx-padding: 3 10;"/>
                                        </HBox>
                                        <TextField fx:id="rotationFieldsField" promptText="customerId:100,200,300 ; region:us,eu,ap" style="-fx-font-size: 11px;"/>

                                        <!-- Random UUID -->
                                        <Label text="Random UUID (select fields, each gets a new UUID per message)" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
                                        <HBox spacing="6" alignment="CENTER_LEFT">
                                            <ComboBox fx:id="uuidFieldPicker" promptText="Pick field" prefWidth="160"/>
                                            <Button text="+ Add" onAction="#handleAddUuid" style="-fx-font-size: 11px; -fx-padding: 3 10;"/>
                                            <Button text="Clear" onAction="#handleClearUuid" style="-fx-font-size: 11px; -fx-padding: 3 10;"/>
                                        </HBox>
