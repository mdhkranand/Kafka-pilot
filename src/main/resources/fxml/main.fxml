                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                            <String fx:value="earliest"/>
                                                            <String fx:value="latest"/>
                                                            <String fx:value="to-datetime"/>
                                                            <String fx:value="shift-by"/>
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>
                                            </HBox>

                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label fx:id="cgResetValueLabel" text="Date/Time:" />
                                                <DatePicker fx:id="cgResetDatePicker" prefWidth="140" promptText="Select date" />
                                                <Spinner fx:id="cgResetHourSpinner" prefWidth="58" editable="true" />
                                                <Label text="h" />
                                                <Spinner fx:id="cgResetMinuteSpinner" prefWidth="58" editable="true" />
                                                <Label text="m" />
                                                <Label fx:id="cgResetValueHintLabel" text=""
                                                       style="-fx-font-size: 10px; -fx-text-fill: #888;"/>
                                            </HBox>

                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="Shift By:" />
                                                <TextField fx:id="cgResetShiftField" promptText="e.g., -100 or +50" prefWidth="140" />
                                                <Label text="offsets (use +/- for direction)" style="-fx-font-size: 10px; -fx-text-fill: #888;"/>
                                            </HBox>

                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Button text="Reset Offsets" onAction="#handleResetOffsets"
                                                        styleClass="btn-orange" style="-fx-font-size: 12px;"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="cgResetStatusLabel" text=""
                                                       style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                                            </HBox>
                                        </VBox>
                                    </TitledPane>

                                    
                                </VBox>
                            </ScrollPane>
                        </center>
                    </BorderPane>
                </Tab>

            </TabPane>

            <!-- ===== Shared console (both tabs) ===== -->
            <VBox fx:id="pushConsoleBox" spacing="0" style="-fx-background-color: #1e1e1e; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;"
                  prefHeight="0" minHeight="0" visible="false" managed="false" VBox.vgrow="NEVER">
                <TextArea fx:id="consoleOutput" editable="false" VBox.vgrow="ALWAYS"
                          style="-fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-text-fill: #e0e0e0; -fx-control-inner-background: #1e1e1e;"
                          promptText="Console output appears here..."/>
            </VBox>

            <!-- Console Toggle Bar (always visible) -->
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 3 10 3 10; -fx-background-color: #2c3e50; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;">
                <Button fx:id="toggleConsoleButton" text="▲ Logs" onAction="#handleToggleConsole"
                        styleClass="btn-dark" style="-fx-font-size: 11px; -fx-padding: 2 8;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="clearConsoleButton" text="Clear" onAction="#handleClear"
                        styleClass="btn-dark" style="-fx-font-size: 11px; -fx-padding: 2 8;" visible="false" managed="false"/>
                <Button fx:id="exportConsoleButton" text="Export" onAction="#handleExportResults"
                        styleClass="btn-dark" style="-fx-font-size: 11px; -fx-padding: 2 8;" visible="false" managed="false"/>
            </HBox>

            <!-- JVM Metrics bar -->
            <HBox spacing="20" alignment="CENTER_LEFT"
                  style="-fx-padding: 3 15 3 15; -fx-background-color: #1a252f; -fx-border-color: #2c3e50; -fx-border-width: 1 0 0 0;">
                <Label text="JVM:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Heap:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10px;"/>
                    <Label fx:id="metricsHeapLabel" text="-- MB / -- MB"
                           style="-fx-text-fill: #27ae60; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Threads:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10px;"/>
                    <Label fx:id="metricsThreadsLabel" text="--"
                           style="-fx-text-fill: #3498db; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="CPU:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10px;"/>
                    <Label fx:id="metricsCpuLabel" text="--%"
                           style="-fx-text-fill: #e67e22; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
                <HBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="GC:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10px;"/>
                    <Label fx:id="metricsGcLabel" text="-- collections"
                           style="-fx-text-fill: #9b59b6; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>
        </VBox>
    </center>

    <!-- Hidden holders for fx:ids still referenced by controller -->
    <bottom>
        <VBox managed="false" visible="false" maxHeight="0" minHeight="0" prefHeight="0">
            <TextField fx:id="sourceTopicField"/>
            <TextField fx:id="sourcePartitionField"/>
            <TextArea fx:id="messageTemplateArea"/>
        </VBox>
    </bottom>


</BorderPane>
